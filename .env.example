# Local runtime configuration. Copy to .env and fill in local values.
# Never commit .env or private key files.

KALSHI_TEMPS_DB=data/kalshi_temps.sqlite3

# Read-only Kalshi market discovery/snapshot integration.
# Production:
KALSHI_API_BASE_URL=https://external-api.kalshi.com/trade-api/v2
# Demo:
# KALSHI_API_BASE_URL=https://external-api.demo.kalshi.co/trade-api/v2

KALSHI_API_KEY_ID=your-kalshi-api-key-id
KALSHI_API_PRIVATE_KEY_PATH=/absolute/path/to/kalshi-private-key.pem
KALSHI_API_TIMEOUT_SECONDS=10
